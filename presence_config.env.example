# MQTT Broker
MQTT_BROKER=192.168.1.100
MQTT_PORT=1883
MQTT_USER=your_mqtt_username
MQTT_PASS=your_mqtt_password

# Serial port for LD2420 (after enabling UART on Pi)
SERIAL_PORT=/dev/serial0
SERIAL_BAUD=256000

# HDMI-CEC screen power control (true/false)
HDMI_POWER_CONTROL=true

# Minimum seconds the screen stays ON once triggered
MIN_ON_TIME=20

# Still energy threshold — sensor reports 0-100+; baseline ~3-5, close range 50-100
STILL_ENERGY_THRESHOLD=50

# Confirm/release frames (at ~10Hz update rate)
CONFIRM_FRAMES=5
RELEASE_FRAMES=10

# LD2420 gate config (max gate to enable)
MAX_GATE=1

# Gate 0 sensitivity (default 30 if not set)
GATE0_MOVING=20
GATE0_STATIC=20

# MQTT discovery prefix
DISCOVERY_PREFIX=homeassistant
