# ==================== MQTT ====================
MQTT_BROKER=mqtt_broker_ip
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=

# ==================== Telegram Bot ====================
TELEGRAM_BOT_TOKEN=

# ==================== Home Assistant ====================
HA_URL=http://home-assistant-ip:8123
HA_TOKEN=
# ==================== Bot internals (optional, sensible defaults if omitted) ====================
# Where the bot keeps its SQLite database. Inside the container this should stay
# /data/dashboard.db to match the docker-compose volume mount.
DB_PATH=/data/dashboard.db
LOG_PATH=/var/log/telegram_bot.log
LOG_LEVEL=INFO

# ==================== General ====================
TZ=Europe/London
